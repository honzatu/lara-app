# LARA App Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your real .env — it contains your LARA password.

# Go Backend
PORT=8400
ENV=production

# LARA device password (web admin password of your LARA units,
# factory default is "elkoep"; change it on the device!)
LARA_USER=admin
LARA_PASS=your_lara_password

# ── THE ONE NETWORK SETTING THAT MATTERS ──────────────────────────────
# LAN_HOST = the LAN IP of the machine running docker compose (NAS, Pi…).
# Your physical LARA fetches YouTube audio and https radio streams from
# this address. Without it, YouTube and https-only stations won't play.
LAN_HOST=192.168.1.10

# Music bridge (advanced — defaults are fine)
# BRIDGE_PORT         — host port the bridge is published on (default 8282)
# BRIDGE_INTERNAL_URL — how the backend reaches the bridge (docker service name)
# BRIDGE_LAN_URL      — override the derived http://LAN_HOST:BRIDGE_PORT
BRIDGE_PORT=8282
BRIDGE_INTERNAL_URL=http://bridge:8282
#BRIDGE_LAN_URL=

# OPTIONAL: LMS / Squeezebox "Audio Zone" mode — OFF by default.
# The direct binary protocol above is the primary, recommended way to control
# LARA and needs none of this. Only enable LMS if you specifically want to
# drive LARA as a Squeezebox player (e.g. for multi-room). Then also start the
# container: docker compose --profile lms up -d
ENABLE_LMS=false
LMS_HOST=localhost
LMS_PORT=9001
LMS_CLI_PORT=9090

# Frontend — leave EMPTY (recommended): the UI then talks to the backend
# through nginx on the same origin, which works from any device on your LAN.
# Only set these when running the frontend dev server outside docker.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=
