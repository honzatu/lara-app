# LARA App Configuration
# Copy this file to .env and fill in your values

# Go Backend
PORT=8400
ENV=production

# LARA Devices (auto-discovered, or set manually)
# LARA_DEVICES=192.168.1.220,192.168.1.221,192.168.1.222

# LARA Authentication (same on all devices, default from factory)
LARA_USER=admin
LARA_PASS=your_lara_password

# LMS (Logitech Media Server)
LMS_HOST=localhost
LMS_PORT=9001
LMS_CLI_PORT=9090

# Music Bridge
BRIDGE_PORT=8282

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8400
NEXT_PUBLIC_WS_URL=ws://localhost:8400
