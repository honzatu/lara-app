# LARA App Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your real .env — it contains your LARA password.

# Go Backend
PORT=8400
ENV=production

# LARA device password (web admin password of your LARA units,
# factory default is "elkoep"; change it on the device!)
LARA_USER=admin
LARA_PASS=your_lara_password

# Music bridge (YouTube Music playback)
# BRIDGE_INTERNAL_URL — how the backend reaches the bridge (docker service name)
# BRIDGE_LAN_URL      — how the physical LARA device reaches the bridge:
#                       your docker host's LAN IP + port 8282. REQUIRED for YouTube.
BRIDGE_INTERNAL_URL=http://bridge:8282
BRIDGE_LAN_URL=http://192.168.1.10:8282

# OPTIONAL: LMS (Logitech Media Server, Squeezebox "Audio Zone" mode)
# Only used when you start the lms profile: docker compose --profile lms up -d
LMS_HOST=localhost
LMS_PORT=9001
LMS_CLI_PORT=9090

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8400
NEXT_PUBLIC_WS_URL=ws://localhost:8400
